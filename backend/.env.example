# Copy to .env and adjust for your machine (never commit .env)

PROJECT_NAME=Arce Sabin Engineering (ASE) Backend

# PostgreSQL (docker-compose + app)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ase
POSTGRES_USER=ase
POSTGRES_PASSWORD=change-me

# SQLAlchemy URL (required for app + Alembic)
DATABASE_URL=postgresql+psycopg://ase:change-me@localhost:5432/ase

# pgAdmin (docker-compose only)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

# JWT — generate a strong random value for production
JWT_SECRET_KEY=change-me-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# MVP: hide legacy multi-tenant HTTP routes
MVP_MODE=true

# Demo seed scripts (scripts/database/seed_*.py, seed_demo_rbac.py)
# Used only in local/dev; do not use weak passwords in production.
DEMO_SEED_PASSWORD=ChangeMeDemo123!

# Optional integrations (not required for MVP)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
