# Copy to .env (never commit .env). App uses DATABASE_URL only.

# Local Docker (docker compose up -d in backend/):
# DATABASE_URL=postgresql+psycopg://ase:ase@127.0.0.1:5432/ase

# Supabase: Project Settings → Database → Connection string
# Use "Session pooler" (port 6543) — works better on Windows than direct db.*.supabase.co
# Paste the full URI (postgresql:// or postgres:// is OK; sslmode=require is added automatically)

DATABASE_URL=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Access JWT lifetime (minutes). After expiry, SPA must call POST /auth/refresh (handled by api client).
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
MVP_MODE=true

# Comma-separated origins for browser clients (add your production SPA URL).
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-app.vercel.app
