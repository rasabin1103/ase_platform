# Copy to .env (never commit .env).
# The app, Alembic, and all scripts use ONLY this variable for Postgres (no POSTGRES_* in Python).

# --- Supabase (recommended) ---
# Dashboard → Project Settings → Database → Connection string → Session pooler (port 6543)
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# --- Local Docker only (optional) ---
# DATABASE_URL=postgresql+psycopg://ase:ase@127.0.0.1:5432/ase

DATABASE_URL=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
TWO_FACTOR_PENDING_TOKEN_EXPIRE_MINUTES=5

# TOTP authenticator (Google Authenticator, Authy, 1Password, Bitwarden)
TOTP_ISSUER=Arce Sabin Engineering
TOTP_DIGITS=6
TOTP_INTERVAL_SECONDS=30

MVP_MODE=true

# Comma-separated origins for browser clients (add your production SPA URL).
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://www.arcesabinengineering.com

FRONTEND_URL=http://localhost:5173

# Transactional email (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=contact@arcesabinengineering.com
CONTACT_INBOX_EMAIL=contact@arcesabinengineering.com
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60

# Dev: SMS codes may appear in API when SMS_DEV_LOG_ONLY=true (email links are backend logs only)
VERIFICATION_DEV_EXPOSE=true

# SMS verification (Twilio) — optional
SMS_DEV_LOG_ONLY=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
