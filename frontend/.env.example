# Copy to .env.local or .env (never commit real .env files)

# Backend API base URL (must include /api/v1 — see api/client.ts)
VITE_API_URL=http://localhost:8000/api/v1

# Tokens: localStorage `ase.access_token` (mirrored to `access_token`). SPA auto-refreshes access JWT on 401 via POST /auth/refresh.
# Optional: logout if no successful API response for N minutes (requires user activity hitting the API):
# VITE_SESSION_IDLE_MINUTES=120
